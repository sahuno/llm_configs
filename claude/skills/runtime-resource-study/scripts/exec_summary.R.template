#!/usr/bin/env Rscript
# Author: {{USER}}
# Date: {{DATE}}
# Purpose: One-page (US Letter portrait, 8.5x11) executive summary for the {{TOOL_NAME}} {{COMMAND}} benchmark study. Composes title, TL;DR, headline numbers, two key figures, recommendations, and references using cowplot::ggdraw + draw_label.

suppressPackageStartupMessages({
  library(readr); library(dplyr); library(ggplot2); library(tidyr); library(scales)
  library(cowplot); library(patchwork)
})

set.seed(42)

# === EDIT: paths to your stage data ===
ROOT       <- "{{PROJECT_ROOT}}/results"
STAGE3_CSV <- file.path(ROOT, "{{STAGE3_DIR}}/benchmark.csv")
COMBINED_CSV <- file.path(ROOT, "combined_stages.csv")    # produced by Stage 6/7 analysis
OUT        <- file.path(ROOT, "exec_summary")
for (sub in c("png","pdf","svg")) dir.create(file.path(OUT, sub), showWarnings = FALSE, recursive = TRUE)

# === EDIT: text content ===
TITLE       <- "{{TOOL_NAME}} {{COMMAND}} - benchmark & predictive model"
SUBTITLE    <- sprintf("%s | %s | MSKCC HPC cpushort, Intel Xeon Gold 6348 | tool v{{TOOL_VERSION}}",
                       "{{USER}}", format(Sys.Date()))
TLDR_LINES <- c(
  "Production config:  {{HEADLINE_CONFIG}}",
  "  -> {{HEADLINE_WALL_SMALL}} on a {{SMALL_INPUT_DESC}}",
  "  -> {{HEADLINE_WALL_LARGE}} on a {{LARGE_INPUT_DESC}}",
  "",
  "Dead factors: {{DEAD_FACTORS_DESC}}",
  "",
  "Trap: {{TRAP_DESC}}",
  "",
  "Container vs conda: {{BUILD_MODE_VERDICT}}",
  "",
  "Hardware: cpushort Xeon Gold 6348; exclude isca071."
)
HEADLINE_NUMBERS <- c(
  "Total compute spent:    {{TOTAL_COMPUTE}}",
  "Jobs run:               {{TOTAL_JOBS}}",
  "Conditions tested:      {{TOTAL_CONDITIONS}}",
  "Inputs spanned:         {{N_RANGE}}",
  "                        {{SIZE_RANGE}}",
  "Best-config wall:       {{BEST_WALL}}   CV {{BEST_CV}}",
  "Model fit (combined):   R^2 = {{R2}}",
  "Validation error:       +/- {{VAL_ERR_PCT}}%",
  "RSS ceiling:            {{RSS_CEILING}}"
)
RECO_LINES <- c(
  "Snakemake / Nextflow rule defaults:",
  "  threads:    {{THREADS_REC}}",
  "  args:       {{ARGS_REC}}",
  "  container:  {{CONTAINER_PATH}}",
  "",
  "Resource sizing (apply +30% safety):",
  "  runtime_s = {{WALL_FORMULA}}",
  "  mem_GB    = {{RSS_FORMULA}}"
)

# ===========================================================================
# Two figures — you usually plug in main effects + obs-vs-pred
# ===========================================================================
theme_panel <- theme_classic(base_size = 12, base_family = "sans") +
  theme(plot.title = element_text(face = "bold", size = 13, hjust = 0),
        plot.subtitle = element_text(size = 10, color = "grey30"),
        panel.grid.major.y = element_line(color = "grey92"),
        plot.margin = margin(4, 6, 4, 6),
        strip.text = element_text(face = "bold", size = 10),
        strip.background = element_blank(),
        legend.position = "right",
        legend.text = element_text(size = 8),
        legend.key.size = unit(0.4, "cm"))
OKABE <- c("#0072B2", "#E69F00", "#D55E00", "#009E73", "#999999", "#CC79A7")

# Figure 1 — Stage 3 main effects (replace with your data)
df3 <- read_csv(STAGE3_CSV, show_col_types = FALSE)
me_long <- df3 %>%
  select(wall_s, threads, mem_per_thread, compression_level) %>%
  mutate(across(c(threads, mem_per_thread, compression_level), as.factor)) %>%
  pivot_longer(-wall_s, names_to = "factor", values_to = "level") %>%
  group_by(factor, level) %>%
  summarise(mean_wall = mean(wall_s), se = sd(wall_s)/sqrt(n()), .groups = "drop")
p_main <- ggplot(me_long, aes(x = level, y = mean_wall, group = factor)) +
  geom_line(color = OKABE[1], linewidth = 0.9) +
  geom_errorbar(aes(ymin = mean_wall - se, ymax = mean_wall + se), width = 0.12, linewidth = 0.5) +
  geom_point(size = 3.5, color = OKABE[1]) +
  facet_wrap(~factor, scales = "free_x", nrow = 1) +
  labs(x = NULL, y = "Mean wall time (s)",
       title = "Main effects",
       subtitle = "Stage 3 factorial; error bars = SE marginal to each level") +
  theme_panel

# Figure 2 — Combined obs-vs-predicted (load combined CSV from Stage 7)
df_combined <- if (file.exists(COMBINED_CSV)) read_csv(COMBINED_CSV, show_col_types = FALSE) else df3
# Assumes combined_stage.csv has columns: wall_s, predicted, stage_label
p_obs <- if ("predicted" %in% names(df_combined)) {
  ggplot(df_combined, aes(x = predicted, y = wall_s, color = stage_label)) +
    geom_abline(slope = 1, intercept = 0, linetype = "dashed", color = "grey50") +
    geom_point(size = 2.5, alpha = 0.85) +
    scale_color_manual(values = OKABE[c(1,3,2,4)], name = NULL) +
    scale_x_continuous(trans = "log10", labels = label_number(suffix = "s")) +
    scale_y_continuous(trans = "log10", labels = label_number(suffix = "s")) +
    labs(x = "Predicted wall", y = "Observed wall",
         title = "Model validates across input range",
         subtitle = "Out-of-sample within stated error bounds") +
    theme_panel
} else {
  ggplot(df3, aes(x = wall_s, y = peak_rss_kb / 1024 / 1024)) +
    geom_point(size = 2.5, color = OKABE[3], alpha = 0.85) +
    labs(x = "Wall time (s)", y = "Peak RSS (GB)",
         title = "Wall vs RSS across factorial",
         subtitle = "Replace with obs-vs-predicted when Stage 6 data available") +
    theme_panel
}

fig_row <- p_main + p_obs + plot_layout(widths = c(1.4, 1))

# ===========================================================================
# Compose the page
# ===========================================================================
W <- 8.5; H <- 11
page <- ggdraw() +
  draw_label(TITLE, x = 0.04, y = 0.97, hjust = 0, vjust = 1, fontface = "bold", size = 22) +
  draw_label(SUBTITLE, x = 0.04, y = 0.94, hjust = 0, vjust = 1, size = 11, colour = "grey25") +
  draw_line(x = c(0.04, 0.96), y = 0.925, size = 0.5, colour = "grey60") +
  draw_label("TL;DR", x = 0.04, y = 0.905, hjust = 0, vjust = 1, fontface = "bold", size = 13) +
  draw_label(paste(TLDR_LINES, collapse = "\n"), x = 0.04, y = 0.885, hjust = 0, vjust = 1, size = 9.5, colour = "grey15") +
  draw_label("HEADLINE NUMBERS", x = 0.55, y = 0.905, hjust = 0, vjust = 1, fontface = "bold", size = 13) +
  draw_label(paste(HEADLINE_NUMBERS, collapse = "\n"), x = 0.55, y = 0.885, hjust = 0, vjust = 1,
             size = 9.5, colour = "grey15", fontfamily = "mono") +
  draw_plot(fig_row, x = 0.04, y = 0.30, width = 0.92, height = 0.32) +
  draw_label("RECOMMENDATIONS", x = 0.04, y = 0.275, hjust = 0, vjust = 1, fontface = "bold", size = 13) +
  draw_label(paste(RECO_LINES, collapse = "\n"), x = 0.04, y = 0.255, hjust = 0, vjust = 1,
             size = 9.5, colour = "grey15", fontfamily = "mono") +
  draw_line(x = c(0.04, 0.96), y = 0.06, size = 0.4, colour = "grey60") +
  draw_label("Full report: REPORT.md      Model: model.yaml      Raw data: results/*/benchmark.csv",
             x = 0.04, y = 0.04, hjust = 0, vjust = 1, size = 8.5, colour = "grey30", fontfamily = "mono")

ggsave(file.path(OUT, "png", "exec_summary.png"), page, width = W, height = H, dpi = 200, bg = "white")
ggsave(file.path(OUT, "pdf", "exec_summary.pdf"), page, width = W, height = H, dpi = 200, bg = "white")
ggsave(file.path(OUT, "svg", "exec_summary.svg"), page, width = W, height = H, bg = "white")
cat("Saved: exec_summary.{png,pdf,svg}  (US Letter portrait, 8.5x11)\n")
